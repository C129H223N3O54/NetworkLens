<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════
         SIDEFORGE DARK THEME
         Ember / Moss / Anvil — warm grays, no blue
         ═══════════════════════════════════════════ -->

    <!-- Surfaces (Anvil warm anthracite) -->
    <Color x:Key="BgDeepColor">#FF0A0A0A</Color>
    <Color x:Key="BgMainColor">#FF0F0F0F</Color>
    <Color x:Key="BgCardColor">#FF1A1A1A</Color>
    <Color x:Key="BgCardHoverColor">#FF1F1F1F</Color>
    <Color x:Key="BgSidebarColor">#FF141414</Color>

    <!-- Ember (Primary accent — orange) -->
    <Color x:Key="AccentColor">#FFF07E2D</Color>
    <Color x:Key="AccentDimColor">#FFE8600A</Color>
    <Color x:Key="AccentGlowColor">#33F07E2D</Color>

    <!-- Text (warm neutrals) -->
    <Color x:Key="TextPrimaryColor">#FFF5F5F5</Color>
    <Color x:Key="TextSecondaryColor">#FFB4B2A9</Color>
    <Color x:Key="TextMutedColor">#FF888780</Color>

    <!-- Borders (Anvil) -->
    <Color x:Key="BorderColor">#FF2C2C2A</Color>
    <Color x:Key="BorderAccentColor">#FFF07E2D</Color>

    <!-- Status -->
    <Color x:Key="StatusOnlineColor">#FF74A732</Color>
    <Color x:Key="StatusWarningColor">#FFBA7517</Color>
    <Color x:Key="StatusOfflineColor">#FFDC2626</Color>

    <!-- Sidebar selection -->
    <Color x:Key="SidebarActiveColor">#FF2A1906</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgDeepBrush"        Color="{StaticResource BgDeepColor}"/>
    <SolidColorBrush x:Key="BgMainBrush"        Color="{StaticResource BgMainColor}"/>
    <SolidColorBrush x:Key="BgCardBrush"        Color="{StaticResource BgCardColor}"/>
    <SolidColorBrush x:Key="BgCardHoverBrush"   Color="{StaticResource BgCardHoverColor}"/>
    <SolidColorBrush x:Key="BgSidebarBrush"     Color="{StaticResource BgSidebarColor}"/>
    <SolidColorBrush x:Key="AccentBrush"        Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDimBrush"     Color="{StaticResource AccentDimColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"     Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="BorderBrush"        Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderAccentBrush"  Color="{StaticResource BorderAccentColor}"/>
    <SolidColorBrush x:Key="StatusOnlineBrush"  Color="{StaticResource StatusOnlineColor}"/>
    <SolidColorBrush x:Key="StatusWarningBrush" Color="{StaticResource StatusWarningColor}"/>
    <SolidColorBrush x:Key="StatusOfflineBrush" Color="{StaticResource StatusOfflineColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActiveColor}"/>
    <SolidColorBrush x:Key="TransparentBrush"   Color="Transparent"/>

</ResourceDictionary>
