<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════
         SIDEFORGE LIGHT THEME
         Ember / Moss / Anvil — warm off-white
         ═══════════════════════════════════════════ -->

    <!-- Surfaces (Anvil warm off-white) -->
    <Color x:Key="BgDeepColor">#FFE5E5E0</Color>
    <Color x:Key="BgMainColor">#FFFAFAF7</Color>
    <Color x:Key="BgCardColor">#FFFFFFFF</Color>
    <Color x:Key="BgCardHoverColor">#FFF1EFE8</Color>
    <Color x:Key="BgSidebarColor">#FFF1EFE8</Color>

    <!-- Ember (Primary accent — orange) -->
    <Color x:Key="AccentColor">#FFE8600A</Color>
    <Color x:Key="AccentDimColor">#FFCC5208</Color>
    <Color x:Key="AccentGlowColor">#33E8600A</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#FF1A1A1A</Color>
    <Color x:Key="TextSecondaryColor">#FF5F5E5A</Color>
    <Color x:Key="TextMutedColor">#FF888780</Color>

    <!-- Borders -->
    <Color x:Key="BorderColor">#FFD3D1C7</Color>
    <Color x:Key="BorderAccentColor">#FFE8600A</Color>

    <!-- Status -->
    <Color x:Key="StatusOnlineColor">#FF639922</Color>
    <Color x:Key="StatusWarningColor">#FFBA7517</Color>
    <Color x:Key="StatusOfflineColor">#FF991B1B</Color>

    <!-- Sidebar selection -->
    <Color x:Key="SidebarActiveColor">#FFFDD9BC</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgDeepBrush"        Color="{StaticResource BgDeepColor}"/>
    <SolidColorBrush x:Key="BgMainBrush"        Color="{StaticResource BgMainColor}"/>
    <SolidColorBrush x:Key="BgCardBrush"        Color="{StaticResource BgCardColor}"/>
    <SolidColorBrush x:Key="BgCardHoverBrush"   Color="{StaticResource BgCardHoverColor}"/>
    <SolidColorBrush x:Key="BgSidebarBrush"     Color="{StaticResource BgSidebarColor}"/>
    <SolidColorBrush x:Key="AccentBrush"        Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDimBrush"     Color="{StaticResource AccentDimColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"     Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="BorderBrush"        Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderAccentBrush"  Color="{StaticResource BorderAccentColor}"/>
    <SolidColorBrush x:Key="StatusOnlineBrush"  Color="{StaticResource StatusOnlineColor}"/>
    <SolidColorBrush x:Key="StatusWarningBrush" Color="{StaticResource StatusWarningColor}"/>
    <SolidColorBrush x:Key="StatusOfflineBrush" Color="{StaticResource StatusOfflineColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActiveColor}"/>
    <SolidColorBrush x:Key="TransparentBrush"   Color="Transparent"/>

</ResourceDictionary>
