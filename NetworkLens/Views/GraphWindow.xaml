<Window x:Class="NetworkLens.Views.GraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:NetworkLens.Localization"
        Title="NetworkLens — Graph"
        Width="700" Height="460"
        MinWidth="500" MinHeight="340"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Topmost="False">

    <Border Background="{DynamicResource BgSidebarBrush}" CornerRadius="10"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#FF000000" BlurRadius="32" ShadowDepth="0" Opacity="0.8"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="44"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource BgDeepBrush}" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="◈" FontSize="14" Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TxtTitle" FontFamily="Verdana" FontSize="13"
                                   FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtIp" FontFamily="Consolas" FontSize="12"
                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="32" Height="32" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Cursor="Hand"
                            Click="BtnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="6">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#FFCC0000"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Live stats bar -->
            <Border Grid.Row="1" Background="{DynamicResource BgMainBrush}" Padding="16,10"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Ping -->
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="PING" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}" FontFamily="Verdana"
                                   HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtPing"
                                       FontFamily="Consolas" FontSize="22"
                                       FontWeight="Light" Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="ms" VerticalAlignment="Bottom" Margin="2,0,0,3"
                                       FontFamily="Verdana" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Jitter -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="JITTER" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}" FontFamily="Verdana"
                                   HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtJitterIcon" FontSize="12" VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <TextBlock x:Name="TxtJitter"
                                       FontFamily="Consolas" FontSize="16"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="ms" VerticalAlignment="Bottom" Margin="2,0,0,2"
                                       FontFamily="Verdana" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Min -->
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="MIN" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}" FontFamily="Verdana"
                                   HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtMin"
                                       FontFamily="Consolas" FontSize="16"
                                       Foreground="{DynamicResource StatusOnlineBrush}"/>
                            <TextBlock Text="ms" VerticalAlignment="Bottom" Margin="2,0,0,2"
                                       FontFamily="Verdana" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Avg -->
                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                        <TextBlock Text="AVG" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}" FontFamily="Verdana"
                                   HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtAvg"
                                       FontFamily="Consolas" FontSize="16"
                                       Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="ms" VerticalAlignment="Bottom" Margin="2,0,0,2"
                                       FontFamily="Verdana" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Max -->
                    <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                        <TextBlock Text="MAX" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}" FontFamily="Verdana"
                                   HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtMax"
                                       FontFamily="Consolas" FontSize="16"
                                       Foreground="{DynamicResource StatusWarningBrush}"/>
                            <TextBlock Text="ms" VerticalAlignment="Bottom" Margin="2,0,0,2"
                                       FontFamily="Verdana" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Packet Loss -->
                    <StackPanel Grid.Column="5" HorizontalAlignment="Center">
                        <TextBlock Text="PACKET LOSS" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}" FontFamily="Verdana"
                                   HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtLoss"
                                       FontFamily="Consolas" FontSize="16"
                                       Foreground="{DynamicResource StatusOfflineBrush}"/>
                            <TextBlock Text="%" VerticalAlignment="Bottom" Margin="1,0,0,2"
                                       FontFamily="Verdana" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtLossCount" HorizontalAlignment="Center"
                                   FontFamily="Verdana" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Graph Canvas -->
            <Border Grid.Row="2" Background="{DynamicResource BgDeepBrush}" Margin="12,8">
                <Canvas x:Name="GraphCanvas" SizeChanged="GraphCanvas_SizeChanged"/>
            </Border>

            <!-- Legend -->
            <StackPanel Grid.Row="3" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,0,0,6">
                <Ellipse Width="8" Height="8" Fill="#FFE8600A"
                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock Text="Ping" FontSize="11" Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" FontFamily="Verdana"/>
                <Ellipse Width="8" Height="8" Fill="#FFBA7517"
                         VerticalAlignment="Center" Margin="16,0,5,0"/>
                <TextBlock Text="Jitter (gestrichelt)" FontSize="11" Foreground="{DynamicResource StatusWarningBrush}"
                           VerticalAlignment="Center" FontFamily="Verdana"/>
                <TextBlock x:Name="TxtPointCount" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" Margin="16,0,0,0" FontFamily="Verdana"/>
            </StackPanel>

            <!-- Bottom bar -->
            <Border Grid.Row="4" Background="{DynamicResource BgDeepBrush}" CornerRadius="0,0,10,10"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                <TextBlock Text="{Binding [Graph_Hint], Source={x:Static loc:LocalizationManager.Instance}}"
                           FontFamily="Verdana" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
