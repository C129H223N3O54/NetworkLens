<UserControl x:Class="NetworkLens.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:NetworkLens.Localization"
             Background="{DynamicResource BgMainBrush}"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="28,24,28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding [Report_Title], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource H1}"/>
                    <TextBlock Text="{Binding [Report_FullSubtitle], Source={x:Static loc:LocalizationManager.Instance}}"
                               Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="Verdana" FontSize="13"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="28,0,28,24">
            <StackPanel>

                <!-- Export Card -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{Binding [Report_ExportCurrent], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}"
                                   Margin="0,0,0,16"/>
                        <TextBlock x:Name="TxtNoScan"
                                   Text="{Binding [Report_NoCurrentScan], Source={x:Static loc:LocalizationManager.Instance}}"
                                   FontFamily="Verdana" FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"/>

                        <!-- Export buttons -->
                        <StackPanel x:Name="ExportButtons" Orientation="Horizontal"
                                    Visibility="Collapsed">
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"
                                    Click="BtnExportHtml_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🌐" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding [Rpt_OpenHtml], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"
                                    Click="BtnExportCsv_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" Margin="0,0,6,0"/>
                                    <TextBlock Text="CSV exportieren"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}"
                                    Click="BtnExportJson_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="JSON" Margin="0,0,6,0"
                                               FontFamily="Consolas" FontSize="12"/>
                                    <TextBlock Text="JSON exportieren"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Last export info -->
                        <TextBlock x:Name="TxtLastExport" Margin="0,12,0,0"
                                   FontFamily="Verdana" FontSize="11.5"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Scan History + Diff -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16" Padding="0">
                    <StackPanel>
                        <Grid Margin="16,14,16,12">
                            <TextBlock Text="{Binding [Report_History], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}"/>
                            <Button HorizontalAlignment="Right" Content="{Binding [Report_ClearHistory], Source={x:Static loc:LocalizationManager.Instance}}"
                                    Style="{StaticResource DangerButton}"
                                    Padding="8,4" FontSize="11"
                                    Click="BtnClearHistory_Click"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource BorderBrush}"/>

                        <TextBlock x:Name="TxtNoHistory"
                                   Text="{Binding [Rpt_NoSavedScans], Source={x:Static loc:LocalizationManager.Instance}}"
                                   FontFamily="Verdana" FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="16,16"/>

                        <DataGrid x:Name="HistoryGrid" IsReadOnly="True"
                                  CanUserSortColumns="True" MaxHeight="240"
                                  Visibility="Collapsed"
                                  SelectionChanged="HistoryGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{Binding [Report_DateTime], Source={x:Static loc:LocalizationManager.Instance}}" Binding="{Binding TimestampFormatted}" Width="160"/>
                                <DataGridTextColumn Header="{Binding [Report_Subnet], Source={x:Static loc:LocalizationManager.Instance}}" Binding="{Binding Subnet}" Width="140">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{Binding [Report_DeviceCount], Source={x:Static loc:LocalizationManager.Instance}}" Binding="{Binding OnlineCount}" Width="80"/>
                                <DataGridTextColumn Header="{Binding [Report_Duration], Source={x:Static loc:LocalizationManager.Instance}}" Binding="{Binding DurationFormatted}" Width="80"/>
                                <DataGridTextColumn Header="{Binding [Report_HostsChecked], Source={x:Static loc:LocalizationManager.Instance}}" Binding="{Binding TotalHostsScanned}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Compare section -->
                        <Border x:Name="ComparePanel" Margin="16,12,16,16" Visibility="Collapsed">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="{Binding [Report_Compare], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}"/>
                                    <Button HorizontalAlignment="Right" Content="🔄 Vergleichen"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="10,5" FontSize="12"
                                            Click="BtnCompare_Click"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding [Report_Before], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="CmbBefore">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding TimestampFormatted}" FontFamily="Consolas"/>
                                                        <TextBlock Text=" — " Foreground="{DynamicResource TextMutedBrush}"/>
                                                        <TextBlock Text="{Binding Subnet}" FontFamily="Consolas"
                                                                   Foreground="{DynamicResource AccentBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="→" VerticalAlignment="Center"
                                               HorizontalAlignment="Center" FontSize="18"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding [Report_After], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="CmbAfter">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding TimestampFormatted}" FontFamily="Consolas"/>
                                                        <TextBlock Text=" — " Foreground="{DynamicResource TextMutedBrush}"/>
                                                        <TextBlock Text="{Binding Subnet}" FontFamily="Consolas"
                                                                   Foreground="{DynamicResource AccentBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Diff Result -->
                <Border x:Name="DiffPanel" Style="{StaticResource CardBorder}"
                        Margin="0,0,0,16" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="VERGLEICHS-ERGEBNIS" Style="{StaticResource Label}"
                                   Margin="0,0,0,16"/>

                        <!-- New devices -->
                        <Border x:Name="NewDevSection" Margin="0,0,0,12" Visibility="Collapsed">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0"
                                            Background="#1A00E676" BorderBrush="#3300E676" BorderThickness="1">
                                        <TextBlock x:Name="TxtNewCount" Text="0"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource StatusOnlineBrush}"/>
                                    </Border>
                                    <TextBlock Text="seit dem letzten Scan aufgetaucht" VerticalAlignment="Center"
                                               FontFamily="Verdana" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ItemsControl x:Name="NewDevList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0A00E676" CornerRadius="5"
                                                    Padding="10,6" Margin="0,2">
                                                <TextBlock FontFamily="Consolas" FontSize="12"
                                                           Foreground="{DynamicResource StatusOnlineBrush}">
                                                    <Run Text="+ "/>
                                                    <Run Text="{Binding IpAddress}"/>
                                                    <Run Text="  "/>
                                                    <Run Text="{Binding Hostname}"
                                                         Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <Run Text="  "/>
                                                    <Run Text="{Binding MacAddress}"
                                                         Foreground="{DynamicResource TextMutedBrush}"/>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Disappeared devices -->
                        <Border x:Name="GoneDevSection" Margin="0,0,0,12" Visibility="Collapsed">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0"
                                            Background="#1AFF1744" BorderBrush="#33FF1744" BorderThickness="1">
                                        <TextBlock x:Name="TxtGoneCount" Text="0 verschwunden"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource StatusOfflineBrush}"/>
                                    </Border>
                                    <TextBlock Text="nicht mehr im Netz" VerticalAlignment="Center"
                                               FontFamily="Verdana" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ItemsControl x:Name="GoneDevList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0AFF1744" CornerRadius="5"
                                                    Padding="10,6" Margin="0,2">
                                                <TextBlock FontFamily="Consolas" FontSize="12"
                                                           Foreground="{DynamicResource StatusOfflineBrush}">
                                                    <Run Text="- "/>
                                                    <Run Text="{Binding IpAddress}"/>
                                                    <Run Text="  "/>
                                                    <Run Text="{Binding Hostname}"
                                                         Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- No changes -->
                        <TextBlock x:Name="TxtNoDiff"
                                   Text="{Binding [Rpt_NoChanges], Source={x:Static loc:LocalizationManager.Instance}}"
                                   FontFamily="Verdana" FontSize="13"
                                   Foreground="{DynamicResource StatusOnlineBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
