<UserControl x:Class="NetworkLens.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgMainBrush}"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,24,28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Live-Monitor" Style="{StaticResource H1}"/>
                    <TextBlock Text="Kontinuierliche Ping-Überwachung mit Jitter und Packet-Loss"
                               Margin="0,4,0,0" Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Intervall:" VerticalAlignment="Center" Margin="0,0,8,0"
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox x:Name="CmbInterval" Width="120"
                              SelectionChanged="CmbInterval_SelectionChanged">
                        <ComboBoxItem Content="1s"/>
                        <ComboBoxItem Content="5s"/>
                        <ComboBoxItem Content="10s" IsSelected="True"/>
                        <ComboBoxItem Content="30s"/>
                        <ComboBoxItem Content="60s"/>
                        <ComboBoxItem Content="Dauerhaft"/>
                    </ComboBox>
                    <Button x:Name="BtnStop" Content="⏹ Stop" Style="{StaticResource SecondaryButton}"
                            Margin="12,0,8,0" IsEnabled="False" Click="BtnStop_Click"/>
                    <Button x:Name="BtnStart" Content="▶ Starten" Style="{StaticResource PrimaryButton}"
                            Click="BtnStart_Click"/>
                    <Button Content="? Erklärungen" Style="{StaticResource SecondaryButton}"
                            Margin="12,0,0,0" Click="BtnShowInfo_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Info Panel (aufklappbar) -->
        <Border Grid.Row="1" x:Name="InfoPanel" Margin="28,0,28,12"
                Background="#FF1A1D21" CornerRadius="8"
                BorderBrush="#FF00B4D8" BorderThickness="1"
                Visibility="Collapsed">
            <StackPanel Margin="16,12">
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="BEGRIFFSERKLÄRUNGEN" FontSize="10" FontWeight="Bold"
                               Foreground="#FF4A5568" FontFamily="Segoe UI"/>
                    <Button x:Name="BtnCloseInfo" Content="✕ Schließen"
                            HorizontalAlignment="Right" Foreground="#FF8A9BB0"
                            FontSize="11" Cursor="Hand" Click="BtnCloseInfo_Click"
                            Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#FF22262C" CornerRadius="6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="📡 Ping" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="#FF00B4D8" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#FF8A9BB0" LineHeight="18"
                                       Text="Zeit in ms, die ein Datenpaket zum Gerät und zurück braucht (Round-Trip Time)."/>
                            <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="11"
                                       Foreground="#FF4A5568" Margin="0,8,0,0" LineHeight="17">
                                🟢 &lt;30ms — Sehr gut&#x0a;🟡 30–100ms — Normal&#x0a;🔴 &gt;200ms — Langsam
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#FF22262C" CornerRadius="6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="📊 Jitter" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="#FFFFD600" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#FF8A9BB0" LineHeight="18"
                                       Text="Schwankung des Pings. Hoher Jitter = unzuverlässige Verbindung, auch wenn der Durchschnitt gut ist."/>
                            <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="11"
                                       Foreground="#FF4A5568" Margin="0,8,0,0" LineHeight="17">
                                🟢 &lt;5ms — Stabil&#x0a;🟡 5–20ms — Leichte Schwankungen&#x0a;🔴 &gt;20ms — Instabil
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Background="#FF22262C" CornerRadius="6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="📦 Packet Loss" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="#FFFF1744" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#FF8A9BB0" LineHeight="18"
                                       Text="Pakete ohne Antwort. Verursacht Ruckler, Abbrüche und Aussetzer."/>
                            <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="11"
                                       Foreground="#FF4A5568" Margin="0,8,0,0" LineHeight="17">
                                🟢 0% — Perfekt&#x0a;🟡 1–5% — Leichte Probleme&#x0a;🔴 &gt;5% — Ernsthafte Störung
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Add IP bar -->
        <Border Grid.Row="2" Margin="28,0,28,16">
            <Border Style="{StaticResource CardBorder}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Gerät hinzufügen:" VerticalAlignment="Center"
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" x:Name="TxtAddIp"
                             FontFamily="Cascadia Code, Consolas"
                             KeyDown="TxtAddIp_KeyDown"/>
                    <Button Grid.Column="2" Content="+ Hinzufügen"
                            Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                            Click="BtnAddDevice_Click"/>
                </Grid>
            </Border>
        </Border>

        <!-- Monitor entries or empty state -->
        <Grid Grid.Row="3" Margin="28,0,28,24">
            <Border x:Name="EmptyState" Style="{StaticResource CardBorder}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📡" FontSize="52" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="Kein Gerät überwacht"
                               Style="{StaticResource H2}" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="IP-Adresse oben eingeben oder Gerät aus dem Scan-Tab hinzufügen."
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <ScrollViewer x:Name="CardsScroll" VerticalScrollBarVisibility="Auto"
                          Visibility="Collapsed">
                <ItemsControl x:Name="MonitorCards">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="310" Margin="0,0,16,16"
                                    Style="{StaticResource CardBorder}"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource BorderBrush}">

                                <StackPanel>
                                    <!-- Device header -->
                                    <Grid Margin="0,0,0,12">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding StatusIcon}" FontSize="16"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Device.DisplayName}"
                                                           FontFamily="Segoe UI" FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Device.IpAddress}"
                                                           FontFamily="Cascadia Code, Consolas"
                                                           FontSize="11.5"
                                                           Foreground="{StaticResource AccentBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Content="✕" Style="{StaticResource IconButton}"
                                                FontSize="11" Padding="5"
                                                Tag="{Binding}"
                                                Click="BtnRemoveDevice_Click"/>
                                    </Grid>

                                    <!-- Current ping -->
                                    <Border Background="{StaticResource BgDeepBrush}"
                                            CornerRadius="6" Padding="12,10" Margin="0,0,0,12">
                                        <Grid>
                                            <StackPanel HorizontalAlignment="Left">
                                                <TextBlock Style="{StaticResource Label}"
                                                           Margin="0,0,0,2">PING</TextBlock>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding LastPing}"
                                                               FontFamily="Cascadia Code, Consolas"
                                                               FontSize="28" FontWeight="Light"
                                                               Foreground="{StaticResource AccentBrush}"/>
                                                    <TextBlock Text=" ms" VerticalAlignment="Bottom"
                                                               Margin="2,0,0,4" FontFamily="Segoe UI"
                                                               FontSize="13"
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Style="{StaticResource Label}"
                                                           Margin="0,0,0,2"
                                                           HorizontalAlignment="Right">JITTER</TextBlock>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding JitterIcon}" FontSize="12"
                                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock FontFamily="Cascadia Code, Consolas"
                                                               FontSize="16"
                                                               Foreground="{StaticResource TextPrimaryBrush}">
                                                        <Run Text="{Binding Jitter, StringFormat={}{0:F1}}"/>
                                                        <Run Text=" ms" FontSize="12"
                                                             Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Stats row: Min / Avg / Max -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock Style="{StaticResource Label}"
                                                       HorizontalAlignment="Center" Margin="0,0,0,2"
                                                       ToolTip="Niedrigster gemessener Ping-Wert seit Start des Monitors.">
                                                MIN</TextBlock>
                                            <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource StatusOnlineBrush}">
                                                <Run Text="{Binding MinPing}"/><Run Text="ms" FontSize="11"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock Style="{StaticResource Label}"
                                                       HorizontalAlignment="Center" Margin="0,0,0,2"
                                                       ToolTip="Durchschnittlicher Ping über alle bisherigen Messungen. Aussagekräftiger als ein einzelner Messwert.">
                                                AVG</TextBlock>
                                            <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource AccentBrush}">
                                                <Run Text="{Binding AvgPing, StringFormat={}{0:F0}}"/><Run Text="ms" FontSize="11"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock Style="{StaticResource Label}"
                                                       HorizontalAlignment="Center" Margin="0,0,0,2"
                                                       ToolTip="Höchster gemessener Ping-Wert. Gibt an wie schlecht die Verbindung im schlimmsten Fall war.">
                                                MAX</TextBlock>
                                            <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource StatusWarningBrush}">
                                                <Run Text="{Binding MaxPing}"/><Run Text="ms" FontSize="11"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Packet loss -->
                                    <Border Background="{StaticResource BgDeepBrush}"
                                            CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- Label + Percent + Counter -->
                                            <Grid Grid.Row="0" Margin="0,0,0,5">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="PACKET LOSS"
                                                               Style="{StaticResource Label}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="13"
                                                               Foreground="{StaticResource StatusOfflineBrush}">
                                                        <Run Text="{Binding PacketLoss, StringFormat={}{0:F1}}"/>
                                                        <Run Text="%"/>
                                                    </TextBlock>
                                                    <TextBlock FontFamily="Segoe UI" FontSize="11"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               VerticalAlignment="Center" Margin="6,0,0,0">
                                                        <Run Text="("/>
                                                        <Run Text="{Binding LostPings, Mode=OneWay}"/>
                                                        <Run Text=" / "/>
                                                        <Run Text="{Binding TotalPings, Mode=OneWay}"/>
                                                        <Run Text=" Pakete)"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                            <!-- Progress bar -->
                                            <ProgressBar Grid.Row="1" Minimum="0" Maximum="100"
                                                         Value="{Binding PacketLoss}"
                                                         Foreground="{StaticResource StatusOfflineBrush}"/>
                                        </Grid>
                                    </Border>

                                    <!-- Live Graph: Ping + Jitter -->
                                    <Border Background="{StaticResource BgDeepBrush}"
                                            CornerRadius="6" Padding="8,6" Margin="0,0,0,8"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="SparkCanvas_DoubleClick"
                                            ToolTip="Doppelklick zum Vergr&#246;&#223;ern">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,4">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="7" Height="7"
                                                             Fill="{StaticResource AccentBrush}"
                                                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="Ping" FontSize="10"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                                    <Ellipse Width="7" Height="7"
                                                             Fill="{StaticResource StatusWarningBrush}"
                                                             VerticalAlignment="Center" Margin="10,0,4,0"/>
                                                    <TextBlock Text="Jitter" FontSize="10"
                                                               Foreground="{StaticResource StatusWarningBrush}"
                                                               VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                                </StackPanel>
                                                <TextBlock HorizontalAlignment="Right" FontSize="10"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center" FontFamily="Segoe UI">
                                                    <Run Text="{Binding PingHistory.Count, Mode=OneWay}"/>
                                                    <Run Text=" Messpunkte"/>
                                                </TextBlock>
                                            </Grid>
                                            <Canvas x:Name="SparkCanvas"
                                                    Height="64" ClipToBounds="True"
                                                    Tag="{Binding}"
                                                    Loaded="SparkCanvas_Loaded"
                                                    SizeChanged="SparkCanvas_SizeChanged"
                                                    MouseLeftButtonDown="SparkCanvas_DoubleClick"
                                                    Cursor="Hand"
                                                    ToolTip="Doppelklick zum Vergr&#246;&#223;ern"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Pings counter -->
                                    <TextBlock Margin="0,8,0,0" FontFamily="Segoe UI" FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               HorizontalAlignment="Right">
                                        <Run Text="{Binding TotalPings}"/>
                                        <Run Text=" Pings gesendet · "/>
                                        <Run Text="{Binding LostPings}"/>
                                        <Run Text=" verloren"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>