<UserControl x:Class="NetworkLens.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:NetworkLens.Localization"
             Background="{DynamicResource BgMainBrush}"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,24,28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding [Monitor_Title], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource H1}"/>
                    <TextBlock Text="{Binding [Monitor_Subtitle], Source={x:Static loc:LocalizationManager.Instance}}"
                               Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="Verdana" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding [Monitor_Interval], Source={x:Static loc:LocalizationManager.Instance}}" VerticalAlignment="Center" Margin="0,0,8,0"
                               FontFamily="Verdana" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <ComboBox x:Name="CmbInterval" Width="120"
                              SelectionChanged="CmbInterval_SelectionChanged">
                        <ComboBoxItem Content="1s"/>
                        <ComboBoxItem Content="5s"/>
                        <ComboBoxItem Content="10s" IsSelected="True"/>
                        <ComboBoxItem Content="30s"/>
                        <ComboBoxItem Content="60s"/>
                        <ComboBoxItem Content="{Binding [Monitor_Continuous], Source={x:Static loc:LocalizationManager.Instance}}"/>
                    </ComboBox>
                    <Button x:Name="BtnStop" Content="{Binding [Monitor_StopButton], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource SecondaryButton}"
                            Margin="12,0,8,0" IsEnabled="False" Click="BtnStop_Click"/>
                    <Button x:Name="BtnStart" Content="{Binding [Monitor_StartButton], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource PrimaryButton}"
                            Click="BtnStart_Click"/>
                    <Button Content="{Binding [Monitor_Explanations], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource SecondaryButton}"
                            Margin="12,0,0,0" Click="BtnShowInfo_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Info Panel (aufklappbar) -->
        <Border Grid.Row="1" x:Name="InfoPanel" Margin="28,0,28,12"
                Background="{DynamicResource BgMainBrush}" CornerRadius="8"
                BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                Visibility="Collapsed">
            <StackPanel Margin="16,12">
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="{Binding [Exp_Title], Source={x:Static loc:LocalizationManager.Instance}}" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}" FontFamily="Verdana"/>
                    <Button x:Name="BtnCloseInfo" Content="{Binding [Exp_Close], Source={x:Static loc:LocalizationManager.Instance}}"
                            HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}"
                            FontSize="11" Cursor="Hand" Click="BtnCloseInfo_Click"
                            Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource BgCardBrush}" CornerRadius="6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="{Binding [Exp_PingHeading], Source={x:Static loc:LocalizationManager.Instance}}" FontFamily="Verdana" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontFamily="Verdana" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" LineHeight="18"
                                       Text="{Binding [Exp_PingText], Source={x:Static loc:LocalizationManager.Instance}}"/>
                            <TextBlock TextWrapping="Wrap" FontFamily="Verdana" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0" LineHeight="17" Text="{Binding [Exp_PingScale], Source={x:Static loc:LocalizationManager.Instance}}"/>
                            <Button Content="{Binding [Exp_PingWiki], Source={x:Static loc:LocalizationManager.Instance}}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="6,3" FontSize="11" Margin="0,8,0,0"
                                    HorizontalAlignment="Left"
                                    Tag="Wiki_Ping"
                                    Click="BtnWikiLink_Click"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{DynamicResource BgCardBrush}" CornerRadius="6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="{Binding [Exp_JitterHeading], Source={x:Static loc:LocalizationManager.Instance}}" FontFamily="Verdana" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{DynamicResource StatusWarningBrush}" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontFamily="Verdana" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" LineHeight="18"
                                       Text="{Binding [Exp_JitterText], Source={x:Static loc:LocalizationManager.Instance}}"/>
                            <TextBlock TextWrapping="Wrap" FontFamily="Verdana" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0" LineHeight="17" Text="{Binding [Exp_JitterScale], Source={x:Static loc:LocalizationManager.Instance}}"/>
                            <Button Content="{Binding [Exp_JitterWiki], Source={x:Static loc:LocalizationManager.Instance}}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="6,3" FontSize="11" Margin="0,8,0,0"
                                    HorizontalAlignment="Left"
                                    Tag="Wiki_Jitter"
                                    Click="BtnWikiLink_Click"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Background="{DynamicResource BgCardBrush}" CornerRadius="6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="{Binding [Exp_LossHeading], Source={x:Static loc:LocalizationManager.Instance}}" FontFamily="Verdana" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{DynamicResource StatusOfflineBrush}" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontFamily="Verdana" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" LineHeight="18"
                                       Text="{Binding [Exp_LossText], Source={x:Static loc:LocalizationManager.Instance}}"/>
                            <TextBlock TextWrapping="Wrap" FontFamily="Verdana" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0" LineHeight="17" Text="{Binding [Exp_LossScale], Source={x:Static loc:LocalizationManager.Instance}}"/>
                            <Button Content="{Binding [Exp_LossWiki], Source={x:Static loc:LocalizationManager.Instance}}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="6,3" FontSize="11" Margin="0,8,0,0"
                                    HorizontalAlignment="Left"
                                    Tag="Wiki_PacketLoss"
                                    Click="BtnWikiLink_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Add IP bar -->
        <Border Grid.Row="2" Margin="28,0,28,16">
            <Border Style="{StaticResource CardBorder}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding [Monitor_AddDevice], Source={x:Static loc:LocalizationManager.Instance}}" VerticalAlignment="Center"
                               FontFamily="Verdana" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" x:Name="TxtAddIp"
                             FontFamily="Consolas"
                             KeyDown="TxtAddIp_KeyDown"/>
                    <Button Grid.Column="2" Content="{Binding [Monitor_AddButton], Source={x:Static loc:LocalizationManager.Instance}}"
                            Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                            Click="BtnAddDevice_Click"/>
                </Grid>
            </Border>
        </Border>

        <!-- Monitor entries or empty state -->
        <Grid Grid.Row="3" Margin="28,0,28,24">
            <Border x:Name="EmptyState" Style="{StaticResource CardBorder}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📡" FontSize="52" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding [Monitor_NoDevices], Source={x:Static loc:LocalizationManager.Instance}}"
                               Style="{StaticResource H2}" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding [Monitor_NoDevicesHint], Source={x:Static loc:LocalizationManager.Instance}}"
                               FontFamily="Verdana" FontSize="13"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <ScrollViewer x:Name="CardsScroll" VerticalScrollBarVisibility="Auto"
                          Visibility="Collapsed">
                <ItemsControl x:Name="MonitorCards">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="310" Margin="0,0,16,16"
                                    Style="{StaticResource CardBorder}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource BorderBrush}">

                                <StackPanel>
                                    <!-- Device header -->
                                    <Grid Margin="0,0,0,12">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding StatusIcon}" FontSize="16"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Device.DisplayName}"
                                                           FontFamily="Verdana" FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Device.IpAddress}"
                                                           FontFamily="Consolas"
                                                           FontSize="11.5"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Content="✕" Style="{StaticResource IconButton}"
                                                FontSize="11" Padding="5"
                                                Tag="{Binding}"
                                                Click="BtnRemoveDevice_Click"/>
                                    </Grid>

                                    <!-- Current ping -->
                                    <Border Background="{DynamicResource BgDeepBrush}"
                                            CornerRadius="6" Padding="12,10" Margin="0,0,0,12">
                                        <Grid>
                                            <StackPanel HorizontalAlignment="Left">
                                                <TextBlock Style="{StaticResource Label}"
                                                           Margin="0,0,0,2">PING</TextBlock>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding LastPing}"
                                                               FontFamily="Consolas"
                                                               FontSize="28" FontWeight="Light"
                                                               Foreground="{DynamicResource AccentBrush}"/>
                                                    <TextBlock Text=" ms" VerticalAlignment="Bottom"
                                                               Margin="2,0,0,4" FontFamily="Verdana"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Style="{StaticResource Label}"
                                                           Margin="0,0,0,2"
                                                           HorizontalAlignment="Right">JITTER</TextBlock>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding JitterIcon}" FontSize="12"
                                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock FontFamily="Consolas"
                                                               FontSize="16"
                                                               Foreground="{DynamicResource TextPrimaryBrush}">
                                                        <Run Text="{Binding Jitter, StringFormat={}{0:F1}}"/>
                                                        <Run Text=" ms" FontSize="12"
                                                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Stats row: Min / Avg / Max -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock Style="{StaticResource Label}"
                                                       HorizontalAlignment="Center" Margin="0,0,0,2"
                                                       ToolTip="Niedrigster gemessener Ping-Wert seit Start des Monitors.">
                                                MIN</TextBlock>
                                            <TextBlock FontFamily="Consolas" FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource StatusOnlineBrush}">
                                                <Run Text="{Binding MinPing}"/><Run Text="ms" FontSize="11"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock Style="{StaticResource Label}"
                                                       HorizontalAlignment="Center" Margin="0,0,0,2"
                                                       ToolTip="Durchschnittlicher Ping über alle bisherigen Messungen. Aussagekräftiger als ein einzelner Messwert.">
                                                AVG</TextBlock>
                                            <TextBlock FontFamily="Consolas" FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource AccentBrush}">
                                                <Run Text="{Binding AvgPing, StringFormat={}{0:F0}}"/><Run Text="ms" FontSize="11"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock Style="{StaticResource Label}"
                                                       HorizontalAlignment="Center" Margin="0,0,0,2"
                                                       ToolTip="Höchster gemessener Ping-Wert. Gibt an wie schlecht die Verbindung im schlimmsten Fall war.">
                                                MAX</TextBlock>
                                            <TextBlock FontFamily="Consolas" FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource StatusWarningBrush}">
                                                <Run Text="{Binding MaxPing}"/><Run Text="ms" FontSize="11"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Packet loss -->
                                    <Border Background="{DynamicResource BgDeepBrush}"
                                            CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- Label + Percent + Counter -->
                                            <Grid Grid.Row="0" Margin="0,0,0,5">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding [Monitor_PacketLoss], Source={x:Static loc:LocalizationManager.Instance}}"
                                                               Style="{StaticResource Label}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <TextBlock FontFamily="Consolas" FontSize="13"
                                                               Foreground="{DynamicResource StatusOfflineBrush}">
                                                        <Run Text="{Binding PacketLoss, StringFormat={}{0:F1}}"/>
                                                        <Run Text="%"/>
                                                    </TextBlock>
                                                    <TextBlock FontFamily="Verdana" FontSize="11"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               VerticalAlignment="Center" Margin="6,0,0,0">
                                                        <Run Text="("/>
                                                        <Run Text="{Binding LostPings, Mode=OneWay}"/>
                                                        <Run Text=" / "/>
                                                        <Run Text="{Binding TotalPings, Mode=OneWay}"/>
                                                        <Run Text=" "/><Run Text="{Binding [Monitor_Packets], Source={x:Static loc:LocalizationManager.Instance}, Mode=OneWay}"/><Run Text=")"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                            <!-- Progress bar -->
                                            <ProgressBar Grid.Row="1" Minimum="0" Maximum="100"
                                                         Value="{Binding PacketLoss}"
                                                         Foreground="{DynamicResource StatusOfflineBrush}"/>
                                        </Grid>
                                    </Border>

                                    <!-- Live Graph: Ping + Jitter -->
                                    <Border Background="{DynamicResource BgDeepBrush}"
                                            CornerRadius="6" Padding="8,6" Margin="0,0,0,8"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="SparkCanvas_DoubleClick"
                                            ToolTip="Doppelklick zum Vergr&#246;&#223;ern">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,4">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="7" Height="7"
                                                             Fill="{DynamicResource AccentBrush}"
                                                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="Ping" FontSize="10"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               VerticalAlignment="Center" FontFamily="Verdana"/>
                                                    <Ellipse Width="7" Height="7"
                                                             Fill="{DynamicResource StatusWarningBrush}"
                                                             VerticalAlignment="Center" Margin="10,0,4,0"/>
                                                    <TextBlock Text="Jitter" FontSize="10"
                                                               Foreground="{DynamicResource StatusWarningBrush}"
                                                               VerticalAlignment="Center" FontFamily="Verdana"/>
                                                </StackPanel>
                                                <TextBlock HorizontalAlignment="Right" FontSize="10"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center" FontFamily="Verdana">
                                                    <Run Text="{Binding PingHistory.Count, Mode=OneWay}"/>
                                                    <Run Text=" "/><Run Text="{Binding [Monitor_Datapoints], Source={x:Static loc:LocalizationManager.Instance}, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Grid>
                                            <Canvas x:Name="SparkCanvas"
                                                    Height="64" ClipToBounds="True"
                                                    Tag="{Binding}"
                                                    Loaded="SparkCanvas_Loaded"
                                                    SizeChanged="SparkCanvas_SizeChanged"
                                                    MouseLeftButtonDown="SparkCanvas_DoubleClick"
                                                    Cursor="Hand"
                                                    ToolTip="Doppelklick zum Vergr&#246;&#223;ern"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Pings counter -->
                                    <TextBlock Margin="0,8,0,0" FontFamily="Verdana" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Right">
                                        <Run Text="{Binding TotalPings}"/>
                                        <Run Text=" Pings gesendet · "/>
                                        <Run Text="{Binding LostPings}"/>
                                        <Run Text=" verloren"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>