<Window x:Class="NetworkLens.Views.CategoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:NetworkLens.Localization"
        Title="{Binding [Cat_Title], Source={x:Static loc:LocalizationManager.Instance}}"
        Width="420" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource BgCardBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect Color="#FF000000" BlurRadius="24" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding [Cat_Title], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource H2}"
                       Margin="0,0,0,16"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="CategoryPanel" Orientation="Horizontal"/>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="{Binding [Dlg_Cancel], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0" Click="BtnCancel_Click"/>
                <Button Content="{Binding [Cat_Apply], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource PrimaryButton}"
                        Click="BtnSave_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
