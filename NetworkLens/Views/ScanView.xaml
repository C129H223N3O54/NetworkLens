<UserControl x:Class="NetworkLens.Views.ScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgMainBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,24,28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Netzwerk-Scan" Style="{StaticResource H1}"/>
                    <TextBlock Text="Alle Geräte im lokalen Netzwerk erkennen" Margin="0,4,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⏹ Stop" Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0" IsEnabled="False" x:Name="BtnStop" Click="BtnStop_Click"/>
                    <Button Content="▶ Scan starten" Style="{StaticResource PrimaryButton}"
                            x:Name="BtnScan" Click="BtnScan_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Scan Control Bar -->
        <Border Grid.Row="1" Margin="28,0,28,16">
            <Border Style="{StaticResource CardBorder}" Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Subnetz:" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" x:Name="TxtSubnet"
                             Text="192.168.1.0/24" FontFamily="Cascadia Code, Consolas, Courier New"/>

                    <TextBlock Grid.Column="3" Text="Timeout:" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox Grid.Column="4" x:Name="CmbTimeout" SelectedIndex="1">
                        <ComboBoxItem Content="500ms (schnell)"/>
                        <ComboBoxItem Content="1000ms (Standard)"/>
                        <ComboBoxItem Content="2000ms (langsam)"/>
                    </ComboBox>

                    <Button Grid.Column="6" Content="🔍 Auto-Erkennung"
                            Style="{StaticResource SecondaryButton}" FontSize="12"
                            Click="BtnAutoDetect_Click"/>
                </Grid>
            </Border>
        </Border>

        <!-- Content: Progress + Results -->
        <Grid Grid.Row="2" Margin="28,0,28,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Progress -->
            <Border x:Name="ProgressPanel" Grid.Row="0" Style="{StaticResource CardBorder}"
                    Margin="0,0,0,16" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock x:Name="ProgressLabel" Text="Scanne 192.168.1.0/24 ..."
                                   FontFamily="Segoe UI" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="ProgressPercent" Text="0%"
                                   HorizontalAlignment="Right"
                                   FontFamily="Segoe UI" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"/>
                    </Grid>
                    <ProgressBar Grid.Row="1" x:Name="ScanProgress" Height="6" Value="0" Maximum="100"/>
                    <TextBlock Grid.Row="2" x:Name="ProgressDetail" Margin="0,6,0,0"
                               Text="0 / 254 Hosts geprüft — 0 online"
                               FontFamily="Segoe UI" FontSize="11.5"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </Grid>
            </Border>

            <!-- Empty State -->
            <Border x:Name="EmptyState" Grid.Row="1" Style="{StaticResource CardBorder}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="◈" FontSize="56" Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="Kein Scan durchgeführt" Style="{StaticResource H2}"
                               HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="Klicke auf ▶ Scan starten um alle Geräte im Netzwerk zu finden."
                               FontFamily="Segoe UI" FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,8,0,24"/>
                    <Button Content="▶ Scan starten" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Center" Click="BtnScan_Click"/>
                </StackPanel>
            </Border>

            <!-- Results Table -->
            <Border x:Name="ResultsPanel" Grid.Row="1" Style="{StaticResource CardBorder}"
                    Padding="0" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Table Header Actions -->
                    <Grid Grid.Row="0" Margin="16,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock x:Name="TxtResultCount"
                                       Text="0 Geräte gefunden" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Border x:Name="NewDeviceBadge" Margin="12,0,0,0"
                                    CornerRadius="12" Padding="8,3" Visibility="Collapsed"
                                    Background="#1A00E676" BorderBrush="#3300E676" BorderThickness="1">
                                <TextBlock x:Name="NewDeviceText" Text="0 neue"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource StatusOnlineBrush}"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBox x:Name="TxtSearch" Width="180"
                                     Tag="🔍 Suchen..." Margin="0,0,8,0"
                                     TextChanged="TxtSearch_TextChanged"/>
                            <Button Content="↑↓ Exportieren" Style="{StaticResource SecondaryButton}"
                                    FontSize="12" Padding="10,6" Click="BtnExport_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Device Data Grid -->
                    <DataGrid Grid.Row="1" x:Name="DeviceGrid"
                              CanUserSortColumns="True"
                              SelectionChanged="DeviceGrid_SelectionChanged">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="🔌 Port-Scan" Click="CtxPortScan_Click"/>
                                <MenuItem Header="📡 In Monitor aufnehmen" Click="CtxAddMonitor_Click"/>
                                <Separator/>
                                <MenuItem Header="✏ Alias setzen..." Click="CtxSetAlias_Click"/>
                                <MenuItem Header="🏷 Kategorie..." Click="CtxSetCategory_Click"/>
                                <MenuItem Header="⭐ Favorit" Click="CtxToggleFavorite_Click"/>
                                <Separator/>
                                <MenuItem Header="📋 IP kopieren" Click="CtxCopyIP_Click"/>
                                <MenuItem Header="📋 MAC kopieren" Click="CtxCopyMAC_Click"/>
                                <Separator/>
                                <MenuItem Header="🔗 Ping (Terminal)" Click="CtxPing_Click"/>
                                <MenuItem Header="🔗 Traceroute" Click="CtxTraceroute_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>

                        <DataGrid.Columns>
                            <!-- Status -->
                            <DataGridTemplateColumn Header="●" Width="42" CanUserSort="True" SortMemberPath="StatusSort">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}"
                                                 VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- IP -->
                            <DataGridTextColumn Header="IP-Adresse" Binding="{Binding IpAddress}"
                                               Width="130" SortMemberPath="IpSort">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Hostname -->
                            <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}" Width="160">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Alias -->
                            <DataGridTemplateColumn Header="Alias" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Alias}" VerticalAlignment="Center"
                                                   FontFamily="Segoe UI" FontStyle="Italic"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- MAC -->
                            <DataGridTextColumn Header="MAC-Adresse" Binding="{Binding MacAddress}" Width="140">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/>
                                        <Setter Property="FontSize" Value="11.5"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Hersteller -->
                            <DataGridTextColumn Header="Hersteller" Binding="{Binding Manufacturer}" Width="140">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Ping -->
                            <DataGridTemplateColumn Header="Ping" Width="80" SortMemberPath="ResponseTime">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center" FontFamily="Segoe UI"
                                                   Foreground="{Binding PingColor}">
                                            <TextBlock.Text>
                                                <Binding Path="ResponseTime" StringFormat="{}{0} ms"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Open Ports -->
                            <DataGridTemplateColumn Header="Ports" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding OpenPortCount}" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   FontFamily="Segoe UI" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Favorite -->
                            <DataGridTemplateColumn Header="⭐" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FavoriteIcon}" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" FontSize="14" Cursor="Hand"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
