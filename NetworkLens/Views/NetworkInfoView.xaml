<UserControl x:Class="NetworkLens.Views.NetworkInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:NetworkLens.Localization"
             Background="{DynamicResource BgMainBrush}"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,24,28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding [NetInfo_Title], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource H1}"/>
                    <TextBlock Text="{Binding [NetInfo_FullSubtitle], Source={x:Static loc:LocalizationManager.Instance}}"
                               Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="Verdana" FontSize="13"/>
                </StackPanel>
                <Button Grid.Column="1" Content="↺ Aktualisieren"
                        Style="{StaticResource SecondaryButton}" VerticalAlignment="Center"
                        Click="BtnRefresh_Click"/>
            </Grid>
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1" Padding="28,0,28,24" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ════ ROW 1: Own IP + Public IP ════ -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Local IP -->
                    <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="{Binding [NetInfo_LocalIPCard], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtLocalIp" Text="—"
                                       FontFamily="Consolas" FontSize="18"
                                       Foreground="{DynamicResource AccentBrush}" FontWeight="Light"/>
                            <TextBlock x:Name="TxtSubnetMask" Text="Maske: —" Margin="0,4,0,0"
                                       FontFamily="Verdana" FontSize="11.5"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TxtDhcp" Text="DHCP" Margin="0,2,0,0"
                                       FontFamily="Verdana" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Gateway -->
                    <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="{Binding [NetInfo_GatewayCard], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtGateway" Text="—"
                                       FontFamily="Consolas" FontSize="18"
                                       Foreground="{DynamicResource AccentBrush}" FontWeight="Light"/>
                            <TextBlock x:Name="TxtGatewayPing" Text="Ping: —" Margin="0,4,0,0"
                                       FontFamily="Verdana" FontSize="11.5"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Public IP -->
                    <Border Grid.Column="4" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="{Binding [NetInfo_PublicIPCard], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtPublicIp" Text="Wird geladen…"
                                       FontFamily="Consolas" FontSize="18"
                                       Foreground="{DynamicResource AccentBrush}" FontWeight="Light"/>
                            <Button x:Name="BtnCopyPublicIp" Content="{Binding [NetInfo_Copy], Source={x:Static loc:LocalizationManager.Instance}}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="8,4" FontSize="11" Margin="0,6,0,0"
                                    HorizontalAlignment="Left"
                                    Click="BtnCopyPublicIp_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ════ ROW 2: DNS + WLAN ════ -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- DNS -->
                    <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="{Binding [NetInfo_DnsCard], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                            <ItemsControl x:Name="DnsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontFamily="Consolas" FontSize="13"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="TxtNoDns" Text="{Binding [Stat_NoDnsFound], Source={x:Static loc:LocalizationManager.Instance}}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontFamily="Verdana" FontSize="12" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- WLAN -->
                    <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="{Binding [NetInfo_WlanCard], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                            <StackPanel x:Name="WlanPanel" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Ellipse Width="8" Height="8" Fill="{DynamicResource StatusOnlineBrush}"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Verbunden" FontFamily="Verdana" FontSize="12"
                                               Foreground="{DynamicResource StatusOnlineBrush}"/>
                                </StackPanel>
                                <TextBlock Text="SSID" Style="{StaticResource Label}" Margin="0,6,0,3"/>
                                <TextBlock x:Name="TxtSsid" Text="—"
                                           FontFamily="Verdana" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="TxtWlanAdapter" Text="—" Margin="0,4,0,0"
                                           FontFamily="Verdana" FontSize="11.5"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel x:Name="NoWlanPanel">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{DynamicResource TextMutedBrush}"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding [NetInfo_NoWlan], Source={x:Static loc:LocalizationManager.Instance}}"
                                               FontFamily="Verdana" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding [NetInfo_OnlyLan], Source={x:Static loc:LocalizationManager.Instance}}" Margin="0,6,0,0"
                                           FontFamily="Verdana" FontSize="11.5"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ════ ADAPTER LIST ════ -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16" Padding="0">
                    <StackPanel>
                        <Grid Margin="16,14,16,10">
                            <TextBlock Text="{Binding [NetInfo_Adapters], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}"/>
                            <TextBlock x:Name="TxtAdapterCount" HorizontalAlignment="Right"
                                       FontFamily="Verdana" FontSize="11.5"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource BorderBrush}"/>
                        <ItemsControl x:Name="AdapterList" Margin="0,0,0,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,12" BorderThickness="0,0,0,1"
                                            BorderBrush="{DynamicResource BorderBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8"
                                                    Background="{Binding StatusBg}" VerticalAlignment="Center"
                                                    Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Icon}" FontSize="16"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontFamily="Verdana"
                                                               FontWeight="SemiBold" FontSize="13"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <Border Margin="8,0,0,0" CornerRadius="4" Padding="5,1"
                                                            Background="{Binding StatusBg}">
                                                        <TextBlock Text="{Binding StatusText}" FontSize="10"
                                                                   FontWeight="Bold" Foreground="{Binding StatusFg}"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Margin="0,2,0,0" FontFamily="Verdana" FontSize="11.5"
                                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                                    <Run Text="{Binding IpAddress}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding MacAddress}"
                                                         FontFamily="Consolas" FontSize="11"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Description}" Margin="0,1,0,0"
                                                           FontFamily="Verdana" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                        HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding SpeedText}" FontFamily="Verdana"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding AdapterType}" FontFamily="Verdana"
                                                           FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                                           HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ════ ACTIVE CONNECTIONS ════ -->
                <Border Style="{StaticResource CardBorder}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="16,14,16,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding [NetInfo_Connections], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}"/>
                                <Border Margin="10,0,0,0" Style="{StaticResource AccentBadge}" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtConnCount" Text="0" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                </Border>
                            </StackPanel>
                            <Button Content="↺ Neu laden" HorizontalAlignment="Right"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="8,4" FontSize="11" Click="BtnRefreshConnections_Click"/>
                        </Grid>
                        <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderBrush}"/>
                        <DataGrid Grid.Row="2" x:Name="ConnectionGrid"
                                  MaxHeight="280" IsReadOnly="True" CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{Binding [Conn_Protocol], Source={x:Static loc:LocalizationManager.Instance}}" Binding="{Binding Protocol}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{Binding [Conn_LocalAddr], Source={x:Static loc:LocalizationManager.Instance}}" Binding="{Binding LocalAddress}" Width="180">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{Binding [Conn_RemoteAddr], Source={x:Static loc:LocalizationManager.Instance}}" Binding="{Binding RemoteAddress}" Width="180">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{Binding [Conn_State], Source={x:Static loc:LocalizationManager.Instance}}" Binding="{Binding State}" Width="120"/>
                                <DataGridTextColumn Header="{Binding [Conn_Process], Source={x:Static loc:LocalizationManager.Instance}}" Binding="{Binding ProcessName}" Width="150">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{Binding [Conn_PID], Source={x:Static loc:LocalizationManager.Instance}}" Binding="{Binding Pid}" Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
