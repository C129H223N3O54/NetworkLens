<Window x:Class="NetworkLens.Views.AliasDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:NetworkLens.Localization"
        Title="Alias setzen"
        Width="380" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource BgCardBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect Color="#FF000000" BlurRadius="24" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Alias setzen" Style="{StaticResource H2}" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="1" x:Name="TxtDeviceName" Text=""
                       FontFamily="Verdana" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16"/>

            <TextBox Grid.Row="2" x:Name="TxtAlias"
                     VerticalAlignment="Top"
                     KeyDown="TxtAlias_KeyDown"/>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="{Binding [Dlg_Cancel], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0" Click="BtnCancel_Click"/>
                <Button Content="{Binding [Dlg_Save], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource PrimaryButton}"
                        Click="BtnSave_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
