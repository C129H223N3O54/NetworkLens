<UserControl x:Class="NetworkLens.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgMainBrush}"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="28,24,28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Einstellungen" Style="{StaticResource H1}"/>
                    <TextBlock Text="NetworkLens konfigurieren"
                               Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="Verdana" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="↺ Zurücksetzen" Style="{StaticResource DangerButton}"
                            Margin="0,0,8,0" Click="BtnReset_Click"/>
                    <Button Content="💾 Speichern" Style="{StaticResource PrimaryButton}"
                            Click="BtnSave_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="28,0,28,24">
            <StackPanel>

                <!-- Appearance -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="ERSCHEINUNGSBILD" Style="{StaticResource Label}"
                                   Margin="0,0,0,16"/>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Theme" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <TextBlock FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,12"
                                           Text="Zwischen Dark Mode und Light Mode wechseln. Die Änderung wird sofort angewendet."/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <!-- Dark Mode Button: always dark bg, always light text -->
                            <Border x:Name="BtnThemeDark"
                                    CornerRadius="6" Padding="16,8" Margin="0,0,8,0"
                                    Cursor="Hand" MouseLeftButtonUp="BtnThemeDark_Click"
                                    Background="#FF0F0F0F" BorderThickness="2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtDarkMode" Text="Dark Mode"
                                               FontFamily="Verdana" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#FFF5F5F5" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- Light Mode Button: always light bg, always dark text -->
                            <Border x:Name="BtnThemeLight"
                                    CornerRadius="6" Padding="16,8"
                                    Cursor="Hand" MouseLeftButtonUp="BtnThemeLight_Click"
                                    Background="#FFFAFAFA" BorderThickness="2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtLightMode" Text="Light Mode"
                                               FontFamily="Verdana" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#FF0F0F0F" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Scan Settings -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="SCAN-EINSTELLUNGEN" Style="{StaticResource Label}"
                                   Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ping-Timeout pro Host" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbScanTimeout" SelectedIndex="1">
                                    <ComboBoxItem Content="500 ms"/>
                                    <ComboBoxItem Content="1000 ms (Standard)"/>
                                    <ComboBoxItem Content="2000 ms"/>
                                    <ComboBoxItem Content="3000 ms"/>
                                </ComboBox>
                                <TextBlock Text="Kürzere Timeouts = schnellere Scans, aber evtl. mehr Fehlalarme"
                                           FontFamily="Verdana" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Maximale parallele Threads" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbMaxThreads" SelectedIndex="1">
                                    <ComboBoxItem Content="50"/>
                                    <ComboBoxItem Content="100 (Standard)"/>
                                    <ComboBoxItem Content="200"/>
                                    <ComboBoxItem Content="500 (aggressiv)"/>
                                </ComboBox>
                                <TextBlock Text="Mehr Threads = schnellerer Scan, aber höhere CPU-Last"
                                           FontFamily="Verdana" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Port-Scan Timeout" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbPortTimeout" SelectedIndex="1">
                                    <ComboBoxItem Content="200 ms"/>
                                    <ComboBoxItem Content="500 ms (Standard)"/>
                                    <ComboBoxItem Content="1000 ms"/>
                                    <ComboBoxItem Content="2000 ms"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Auto-Scan beim Start" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <CheckBox x:Name="ChkAutoScan"
                                          Content="Netzwerk-Scan beim Programmstart ausführen"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Monitor Settings -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="LIVE-MONITOR" Style="{StaticResource Label}"
                                   Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Standard-Intervall" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbMonitorInterval" SelectedIndex="2">
                                    <ComboBoxItem Content="1 Sekunde"/>
                                    <ComboBoxItem Content="5 Sekunden"/>
                                    <ComboBoxItem Content="10 Sekunden (Standard)"/>
                                    <ComboBoxItem Content="30 Sekunden"/>
                                    <ComboBoxItem Content="60 Sekunden"/>
                                    <ComboBoxItem Content="Dauerhaft"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Notifications -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="BENACHRICHTIGUNGEN" Style="{StaticResource Label}"/>
                            <CheckBox x:Name="ChkNotifications" HorizontalAlignment="Right"
                                      Content="Benachrichtigungen aktiv"/>
                        </Grid>
                        <StackPanel x:Name="AlertPanel">
                            <CheckBox x:Name="ChkAlertNewDevice" Margin="0,0,0,10"
                                      Content="⚠  Neues unbekanntes Gerät im Netzwerk erkannt"/>
                            <CheckBox x:Name="ChkAlertOffline" Margin="0,0,0,10"
                                      Content="🔴 Überwachtes Gerät offline gegangen"/>
                            <CheckBox x:Name="ChkAlertOnline" Margin="0,0,0,10"
                                      Content="🟢 Gerät wieder online gegangen"/>
                            <CheckBox x:Name="ChkAlertNewPort" Margin="0,0,0,10"
                                      Content="⚡ Neuer offener Port erkannt"/>
                            <CheckBox x:Name="ChkAlertSound"
                                      Content="🔔 Sound bei Alert abspielen"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Output / Paths -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="AUSGABE-PFAD" Style="{StaticResource Label}"
                                   Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="TxtOutputPath"
                                     FontFamily="Consolas" FontSize="12"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="📁 Durchsuchen"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BtnBrowseOutput_Click"/>
                        </Grid>
                        <TextBlock Text="HTML-, CSV- und JSON-Reports werden hier gespeichert."
                                   FontFamily="Verdana" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- App Data paths info -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="APP-DATEN" Style="{StaticResource Label}" Margin="0,0,0,16"/>
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Konfiguration" FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="TxtPathConfig"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Geräte-Daten" FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="TxtPathDevices"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Scan-Verlauf" FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="TxtPathScans"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="📂 App-Ordner öffnen"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="10,6" FontSize="12"
                                    Click="BtnOpenAppData_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- About -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="ÜBER" Style="{StaticResource Label}" Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <!-- SF Logo Tile -->
                            <Border Width="44" Height="44" CornerRadius="8"
                                    Background="#FF1A1A1A"
                                    VerticalAlignment="Center" Margin="0,0,14,0">
                                <Grid>
                                    <TextBlock Text="S" FontFamily="Georgia" FontStyle="Italic"
                                               FontWeight="Bold" FontSize="26" Foreground="#FFE8600A"
                                               HorizontalAlignment="Left" VerticalAlignment="Center"
                                               Margin="6,0,0,2"/>
                                    <TextBlock Text="F" FontFamily="Georgia" FontStyle="Italic"
                                               FontWeight="Bold" FontSize="26" Foreground="#FFF5F5F5"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,6,2"/>
                                </Grid>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Side" FontFamily="Verdana" FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="forge" FontFamily="Verdana" FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                    <TextBlock Text=" / NetworkLens" FontFamily="Verdana" FontSize="14"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center" Margin="6,2,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtVersion"
                                           Text="v1.2.0 — .NET 8 / WPF / Windows x64"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource AccentBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Credits -->
                        <Border Background="{DynamicResource BgDeepBrush}" CornerRadius="6"
                                Padding="14,12" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="💡 Idee &amp; Konzept"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="Jan Erik Mueller"
                                           FontFamily="Verdana" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="🤖 Entwicklung"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="2" Grid.Column="1"
                                            Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Claude (Anthropic)"
                                               FontFamily="Verdana" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text=" — KI-Assistent von Anthropic"
                                               FontFamily="Verdana" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- License -->
                        <Border Background="#0A00B4D8" BorderBrush="#2200B4D8" BorderThickness="1"
                                CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚖" FontSize="14" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center">
                                    <Run Text="MIT License" FontWeight="SemiBold"
                                         Foreground="{DynamicResource AccentBrush}"/>
                                    <Run Text=" — Freie Nutzung, Weitergabe und Modifikation erlaubt."/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Portabler Netzwerkscanner — keine Installation erforderlich."
                                   FontFamily="Verdana" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,12"/>
                        <Button Content="🔗 GitHub öffnen"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,6" FontSize="12"
                                Click="BtnGitHub_Click"/>
                    </StackPanel>
                </Border>

                <!-- Changelog -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="CHANGELOG" Style="{StaticResource Label}" Margin="0,0,0,16"/>

                        <!-- v1.2.0 -->
                        <Expander Margin="0,0,0,8" IsExpanded="True">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{DynamicResource AccentBrush}" CornerRadius="4"
                                            Padding="7,2" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <TextBlock Text="v1.2.0" FontSize="11" FontWeight="Bold"
                                                   Foreground="#FF000000" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Text="Sideforge Design System"
                                               FontFamily="Verdana" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Margin="16,8,0,8">
                                <TextBlock Text="• Migration auf das Sideforge Design-System (Ember / Moss / Anvil)"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Neue Akzentfarbe: Ember-Orange statt Cyan"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Warme Anvil-Grautöne ersetzen kühles Blaugrau"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• SF-Logo + Sideforge Wordmark im Header"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Schriftart: Verdana (UI), Georgia italic (Logo), Consolas (Mono)"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Light + Dark Mode neu kalibriert für die Sideforge-Palette"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                            </StackPanel>
                        </Expander>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4,0,8"/>

                        <!-- v1.1.0 -->
                        <Expander Margin="0,0,0,8" IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{DynamicResource AccentBrush}" CornerRadius="4"
                                            Padding="7,2" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <TextBlock Text="v1.1.0" FontSize="11" FontWeight="Bold"
                                                   Foreground="#FF000000" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Text="Light / Dark Theme"
                                               FontFamily="Verdana" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Margin="16,8,0,8">
                                <TextBlock Text="• Light Mode und Dark Mode Toggle in Einstellungen"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Theme wechselt sofort ohne Neustart"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Theme-Wahl wird gespeichert und beim Start geladen"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Kontextmenü, Monitor, Graph-Fenster folgen dem Theme"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• HTML Report erkennt System-Theme automatisch"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                            </StackPanel>
                        </Expander>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4,0,8"/>

                        <!-- v1.0.0 -->
                        <Expander Margin="0,0,0,0" IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{DynamicResource BgDeepBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="4" Padding="7,2" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <TextBlock Text="v1.0.0" FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Text="Initial Release"
                                               FontFamily="Verdana" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <Border Background="#1A00E676" BorderBrush="#3300E676" BorderThickness="1"
                                            CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="STABLE" FontSize="10" FontWeight="Bold"
                                                   Foreground="{DynamicResource StatusOnlineBrush}"/>
                                    </Border>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Margin="16,8,0,8">
                                <TextBlock Text="• Netzwerk-Scan: Paralleler Ping-Sweep, Live-Ergebnisse, DNS, MAC, Hersteller"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Port-Scanner: Quick / Standard / Full / Custom Profile, Banner-Grabbing"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Netzwerk-Info: IP, Gateway, DNS, WLAN-SSID, Adapter, netstat"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Live-Monitor: Ping/Jitter Graph, Packet Loss, Doppelklick Vollbild"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Intervalle: 1s / 5s / 10s / 30s / 60s / Dauerhaft"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Erklärungen: Ping, Jitter, Packet Loss mit Wikipedia-Links"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Geräte-Verwaltung: Alias, Kategorie, Favoriten (persistent per MAC)"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Reports: HTML (interaktiv), CSV, JSON, Scan-Vergleich"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Kontextmenü: HTTP/HTTPS/FTP/SSH/Telnet/Traceroute/GeoLocate"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Live-Ergebnisse während des Scans"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Auto-Subnetz-Erkennung beim Start"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Self-Contained .exe — kein .NET nötig, Self-Signed Certificate, MIT License"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
