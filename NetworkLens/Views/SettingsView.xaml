<UserControl x:Class="NetworkLens.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgMainBrush}"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="28,24,28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Einstellungen" Style="{StaticResource H1}"/>
                    <TextBlock Text="NetworkLens konfigurieren"
                               Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="Segoe UI" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="↺ Zurücksetzen" Style="{StaticResource DangerButton}"
                            Margin="0,0,8,0" Click="BtnReset_Click"/>
                    <Button Content="💾 Speichern" Style="{StaticResource PrimaryButton}"
                            Click="BtnSave_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="28,0,28,24">
            <StackPanel>

                <!-- Appearance -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="ERSCHEINUNGSBILD" Style="{StaticResource Label}"
                                   Margin="0,0,0,16"/>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Theme" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <TextBlock FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,12"
                                           Text="Zwischen Dark Mode und Light Mode wechseln. Die Änderung wird sofort angewendet."/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="BtnThemeDark"
                                    Background="{DynamicResource AccentBrush}"
                                    CornerRadius="6" Padding="16,8" Margin="0,0,8,0"
                                    Cursor="Hand" MouseLeftButtonUp="BtnThemeDark_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🌙" FontSize="14" Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Dark Mode" FontFamily="Segoe UI"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="Black" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="BtnThemeLight"
                                    Background="{DynamicResource BgDeepBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="16,8"
                                    Cursor="Hand" MouseLeftButtonUp="BtnThemeLight_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="☀️" FontSize="14" Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Light Mode" FontFamily="Segoe UI"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Scan Settings -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="SCAN-EINSTELLUNGEN" Style="{StaticResource Label}"
                                   Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ping-Timeout pro Host" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbScanTimeout" SelectedIndex="1">
                                    <ComboBoxItem Content="500 ms"/>
                                    <ComboBoxItem Content="1000 ms (Standard)"/>
                                    <ComboBoxItem Content="2000 ms"/>
                                    <ComboBoxItem Content="3000 ms"/>
                                </ComboBox>
                                <TextBlock Text="Kürzere Timeouts = schnellere Scans, aber evtl. mehr Fehlalarme"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Maximale parallele Threads" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbMaxThreads" SelectedIndex="1">
                                    <ComboBoxItem Content="50"/>
                                    <ComboBoxItem Content="100 (Standard)"/>
                                    <ComboBoxItem Content="200"/>
                                    <ComboBoxItem Content="500 (aggressiv)"/>
                                </ComboBox>
                                <TextBlock Text="Mehr Threads = schnellerer Scan, aber höhere CPU-Last"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Port-Scan Timeout" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbPortTimeout" SelectedIndex="1">
                                    <ComboBoxItem Content="200 ms"/>
                                    <ComboBoxItem Content="500 ms (Standard)"/>
                                    <ComboBoxItem Content="1000 ms"/>
                                    <ComboBoxItem Content="2000 ms"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Auto-Scan beim Start" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <CheckBox x:Name="ChkAutoScan"
                                          Content="Netzwerk-Scan beim Programmstart ausführen"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Monitor Settings -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="LIVE-MONITOR" Style="{StaticResource Label}"
                                   Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Standard-Intervall" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbMonitorInterval" SelectedIndex="2">
                                    <ComboBoxItem Content="1 Sekunde"/>
                                    <ComboBoxItem Content="5 Sekunden"/>
                                    <ComboBoxItem Content="10 Sekunden (Standard)"/>
                                    <ComboBoxItem Content="30 Sekunden"/>
                                    <ComboBoxItem Content="60 Sekunden"/>
                                    <ComboBoxItem Content="Dauerhaft"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Notifications -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="BENACHRICHTIGUNGEN" Style="{StaticResource Label}"/>
                            <CheckBox x:Name="ChkNotifications" HorizontalAlignment="Right"
                                      Content="Benachrichtigungen aktiv"/>
                        </Grid>
                        <StackPanel x:Name="AlertPanel">
                            <CheckBox x:Name="ChkAlertNewDevice" Margin="0,0,0,10"
                                      Content="⚠  Neues unbekanntes Gerät im Netzwerk erkannt"/>
                            <CheckBox x:Name="ChkAlertOffline" Margin="0,0,0,10"
                                      Content="🔴 Überwachtes Gerät offline gegangen"/>
                            <CheckBox x:Name="ChkAlertOnline" Margin="0,0,0,10"
                                      Content="🟢 Gerät wieder online gegangen"/>
                            <CheckBox x:Name="ChkAlertNewPort" Margin="0,0,0,10"
                                      Content="⚡ Neuer offener Port erkannt"/>
                            <CheckBox x:Name="ChkAlertSound"
                                      Content="🔔 Sound bei Alert abspielen"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Output / Paths -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="AUSGABE-PFAD" Style="{StaticResource Label}"
                                   Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="TxtOutputPath"
                                     FontFamily="Cascadia Code, Consolas" FontSize="12"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="📁 Durchsuchen"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BtnBrowseOutput_Click"/>
                        </Grid>
                        <TextBlock Text="HTML-, CSV- und JSON-Reports werden hier gespeichert."
                                   FontFamily="Segoe UI" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- App Data paths info -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="APP-DATEN" Style="{StaticResource Label}" Margin="0,0,0,16"/>
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Konfiguration" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="TxtPathConfig"
                                           FontFamily="Cascadia Code, Consolas" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Geräte-Daten" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="TxtPathDevices"
                                           FontFamily="Cascadia Code, Consolas" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Scan-Verlauf" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="TxtPathScans"
                                           FontFamily="Cascadia Code, Consolas" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="📂 App-Ordner öffnen"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="10,6" FontSize="12"
                                    Click="BtnOpenAppData_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- About -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="ÜBER" Style="{StaticResource Label}" Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="◈" FontSize="28" Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="NetworkLens" FontFamily="Segoe UI"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="TxtVersion"
                                           Text="v1.1.0 — .NET 8 / WPF / Windows x64"
                                           FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource AccentBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Credits -->
                        <Border Background="{DynamicResource BgDeepBrush}" CornerRadius="6"
                                Padding="14,12" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="💡 Idee &amp; Konzept"
                                           FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="Jan Erik Mueller"
                                           FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="🤖 Entwicklung"
                                           FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="2" Grid.Column="1"
                                            Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Claude (Anthropic)"
                                               FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text=" — KI-Assistent von Anthropic"
                                               FontFamily="Segoe UI" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- License -->
                        <Border Background="#0A00B4D8" BorderBrush="#2200B4D8" BorderThickness="1"
                                CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚖" FontSize="14" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center">
                                    <Run Text="MIT License" FontWeight="SemiBold"
                                         Foreground="{DynamicResource AccentBrush}"/>
                                    <Run Text=" — Freie Nutzung, Weitergabe und Modifikation erlaubt."/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Portabler Netzwerkscanner — keine Installation erforderlich."
                                   FontFamily="Segoe UI" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,12"/>
                        <Button Content="🔗 GitHub öffnen"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,6" FontSize="12"
                                Click="BtnGitHub_Click"/>
                    </StackPanel>
                </Border>

                <!-- Changelog -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="CHANGELOG" Style="{StaticResource Label}" Margin="0,0,0,16"/>

                        <!-- v1.1.0 -->
                        <StackPanel Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Border Background="{DynamicResource AccentBrush}" CornerRadius="4"
                                        Padding="7,2" Margin="0,0,10,0">
                                    <TextBlock Text="v1.1.0" FontSize="11" FontWeight="Bold"
                                               Foreground="#FF000000" FontFamily="Cascadia Code, Consolas"/>
                                </Border>
                                <TextBlock Text="Initial Release"
                                           FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Border Background="#1A00E676" BorderBrush="#3300E676" BorderThickness="1"
                                        CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="STABLE" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource StatusOnlineBrush}"/>
                                </Border>
                            </StackPanel>
                            <TextBlock FontFamily="Segoe UI" FontSize="12" LineHeight="20"
                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">🔍 Netzwerk-Scan</Run>
                                <Run Text="&#x0a;  • Paralleler Ping-Sweep des lokalen Subnetzes"/>
                                <Run Text="&#x0a;  • Automatische Subnetz-Erkennung beim Start"/>
                                <Run Text="&#x0a;  • Live-Ergebnisse während des Scans"/>
                                <Run Text="&#x0a;  • DNS Reverse-Lookup, MAC-Adresse via ARP"/>
                                <Run Text="&#x0a;  • Hersteller-Erkennung via OUI-Datenbank"/>
                                <Run Text="&#x0a;  • Sortierung nach IP aufsteigend"/>
                                <Run Text="&#x0a;  • Suche und Filter in Echtzeit"/>
                                <Run Text="&#x0a;"/>
                                <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">🔌 Port-Scanner</Run>
                                <Run Text="&#x0a;  • Quick / Standard / Full / Custom Profile"/>
                                <Run Text="&#x0a;  • Async TCP Connect Scan mit Banner-Grabbing"/>
                                <Run Text="&#x0a;  • ~60 bekannte Dienste automatisch erkannt"/>
                                <Run Text="&#x0a;"/>
                                <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">📊 Netzwerk-Info</Run>
                                <Run Text="&#x0a;  • Lokale IP, Gateway, Subnetz, DNS-Server"/>
                                <Run Text="&#x0a;  • Öffentliche IP, WLAN-SSID"/>
                                <Run Text="&#x0a;  • Adapter-Liste mit Speed und Status"/>
                                <Run Text="&#x0a;  • Aktive Verbindungen (netstat)"/>
                                <Run Text="&#x0a;"/>
                                <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">📡 Live-Monitor</Run>
                                <Run Text="&#x0a;  • Kontinuierliche Ping-Überwachung"/>
                                <Run Text="&#x0a;  • Live Ping + Jitter Graph (Doppelklick = Vollbild)"/>
                                <Run Text="&#x0a;  • Min / Avg / Max / Jitter / Packet Loss"/>
                                <Run Text="&#x0a;  • Intervall: 1s / 5s / 10s / 30s / 60s / Dauerhaft"/>
                                <Run Text="&#x0a;  • Erklärungen-Panel: Ping, Jitter, Packet Loss"/>
                                <Run Text="&#x0a;  • Wikipedia-Links für weitere Infos"/>
                                <Run Text="&#x0a;"/>
                                <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">🏷 Geräte-Verwaltung</Run>
                                <Run Text="&#x0a;  • Alias, Kategorie, Favoriten, Notizen"/>
                                <Run Text="&#x0a;  • Persistent über Scans hinweg (per MAC)"/>
                                <Run Text="&#x0a;"/>
                                <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">📄 Report &amp; Export</Run>
                                <Run Text="&#x0a;  • HTML-Report mit Filter und Suche"/>
                                <Run Text="&#x0a;  • CSV und JSON Export"/>
                                <Run Text="&#x0a;  • Scan-Vergleich: neue / verschwundene Geräte"/>
                                <Run Text="&#x0a;"/>
                                <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">🖥 Kontextmenü</Run>
                                <Run Text="&#x0a;  • Port-Scan, Monitor, Alias, Kategorie, Favorit"/>
                                <Run Text="&#x0a;  • HTTP / HTTPS / Explorer / FTP / Telnet / SSH"/>
                                <Run Text="&#x0a;  • Ping / Traceroute / GeoLocate"/>
                                <Run Text="&#x0a;  • IP und MAC kopieren"/>
                                <Run Text="&#x0a;"/>
                                <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">⚙ Allgemein</Run>
                                <Run Text="&#x0a;  • Dark Theme, Sidebar-Navigation"/>
                                <Run Text="&#x0a;  • Admin-Erkennung mit Neustart-Option"/>
                                <Run Text="&#x0a;  • Self-Contained .exe — kein .NET nötig"/>
                                <Run Text="&#x0a;  • Self-Signed Code Signing Certificate"/>
                                <Run Text="&#x0a;  • MIT License"/>
                            </TextBlock>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
