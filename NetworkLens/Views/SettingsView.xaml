<UserControl x:Class="NetworkLens.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:NetworkLens.Localization"
             Background="{DynamicResource BgMainBrush}"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="28,24,28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding [Settings_Title], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource H1}"/>
                    <TextBlock Text="{Binding [Settings_Subtitle], Source={x:Static loc:LocalizationManager.Instance}}"
                               Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="Verdana" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{Binding [Settings_Reset], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource DangerButton}"
                            Margin="0,0,8,0" Click="BtnReset_Click"/>
                    <Button Content="{Binding [Settings_Save], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource PrimaryButton}"
                            Click="BtnSave_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="28,0,28,24">
            <StackPanel>

                <!-- Language -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{Binding [Section_Language], Source={x:Static loc:LocalizationManager.Instance}}"
                                   Style="{StaticResource Label}" Margin="0,0,0,16"/>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="{Binding [Lang_Label], Source={x:Static loc:LocalizationManager.Instance}}"
                                           Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                <TextBlock FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,12"
                                           Text="{Binding [Lang_Description], Source={x:Static loc:LocalizationManager.Instance}}"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="BtnLangDe"
                                    CornerRadius="6" Padding="16,8" Margin="0,0,8,0"
                                    Cursor="Hand" MouseLeftButtonUp="BtnLangDe_Click"
                                    Background="{DynamicResource BgCardBrush}" BorderThickness="2">
                                <TextBlock Text="Deutsch"
                                           FontFamily="Verdana" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="BtnLangEn"
                                    CornerRadius="6" Padding="16,8"
                                    Cursor="Hand" MouseLeftButtonUp="BtnLangEn_Click"
                                    Background="{DynamicResource BgCardBrush}" BorderThickness="2">
                                <TextBlock Text="English"
                                           FontFamily="Verdana" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Appearance -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{Binding [Section_Appearance], Source={x:Static loc:LocalizationManager.Instance}}"
                                   Style="{StaticResource Label}" Margin="0,0,0,16"/>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="{Binding [Theme_Label], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <TextBlock FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,12"
                                           Text="{Binding [Theme_Description], Source={x:Static loc:LocalizationManager.Instance}}"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <!-- Dark Mode Button: always dark bg, always light text -->
                            <Border x:Name="BtnThemeDark"
                                    CornerRadius="6" Padding="16,8" Margin="0,0,8,0"
                                    Cursor="Hand" MouseLeftButtonUp="BtnThemeDark_Click"
                                    Background="#FF0F0F0F" BorderThickness="2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtDarkMode" Text="{Binding [Theme_Dark], Source={x:Static loc:LocalizationManager.Instance}}"
                                               FontFamily="Verdana" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#FFF5F5F5" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- Light Mode Button: always light bg, always dark text -->
                            <Border x:Name="BtnThemeLight"
                                    CornerRadius="6" Padding="16,8"
                                    Cursor="Hand" MouseLeftButtonUp="BtnThemeLight_Click"
                                    Background="#FFFAFAFA" BorderThickness="2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtLightMode" Text="{Binding [Theme_Light], Source={x:Static loc:LocalizationManager.Instance}}"
                                               FontFamily="Verdana" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#FF0F0F0F" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Scan Settings -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{Binding [Section_Scan], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}"
                                   Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding [Set_PingTimeout], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbScanTimeout" SelectedIndex="1">
                                    <ComboBoxItem Content="{Binding [TO_500ms], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [TO_1000msDefault], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [TO_2000ms], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [TO_3000ms], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                </ComboBox>
                                <TextBlock Text="{Binding [Set_PingTimeoutHint], Source={x:Static loc:LocalizationManager.Instance}}"
                                           FontFamily="Verdana" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding [Set_MaxThreads], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbMaxThreads" SelectedIndex="1">
                                    <ComboBoxItem Content="{Binding [Th_50], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [Th_100Default], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [Th_200], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [Th_500Aggressive], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                </ComboBox>
                                <TextBlock Text="{Binding [Set_MaxThreadsHint], Source={x:Static loc:LocalizationManager.Instance}}"
                                           FontFamily="Verdana" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding [Set_PortTimeout], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbPortTimeout" SelectedIndex="1">
                                    <ComboBoxItem Content="{Binding [TO_200ms], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [TO_500msDefault], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [TO_1000ms], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [TO_2000ms], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding [Set_AutoScanStart], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <CheckBox x:Name="ChkAutoScan"
                                          Content="{Binding [Set_AutoScanHint], Source={x:Static loc:LocalizationManager.Instance}}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Monitor Settings -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{Binding [Section_Monitor], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}"
                                   Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding [Set_DefaultInterval], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbMonitorInterval" SelectedIndex="2">
                                    <ComboBoxItem Content="{Binding [Int_1Sec], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [Int_5Sec], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [Set_Interval10], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [Int_30Sec], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [Int_60Sec], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [Int_Continuous], Source={x:Static loc:LocalizationManager.Instance}}"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Notifications -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="{Binding [Section_Notify], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}"/>
                            <CheckBox x:Name="ChkNotifications" HorizontalAlignment="Right"
                                      Content="{Binding [Set_NotifyEnabled], Source={x:Static loc:LocalizationManager.Instance}}"/>
                        </Grid>
                        <StackPanel x:Name="AlertPanel">
                            <CheckBox x:Name="ChkAlertNewDevice" Margin="0,0,0,10"
                                      Content="{Binding [Set_NotifyNewDevice], Source={x:Static loc:LocalizationManager.Instance}}"/>
                            <CheckBox x:Name="ChkAlertOffline" Margin="0,0,0,10"
                                      Content="{Binding [Set_NotifyOffline], Source={x:Static loc:LocalizationManager.Instance}}"/>
                            <CheckBox x:Name="ChkAlertOnline" Margin="0,0,0,10"
                                      Content="{Binding [Set_NotifyOnline], Source={x:Static loc:LocalizationManager.Instance}}"/>
                            <CheckBox x:Name="ChkAlertNewPort" Margin="0,0,0,10"
                                      Content="{Binding [Set_NotifyNewPort], Source={x:Static loc:LocalizationManager.Instance}}"/>
                            <CheckBox x:Name="ChkAlertSound"
                                      Content="{Binding [Set_NotifySound], Source={x:Static loc:LocalizationManager.Instance}}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Output / Paths -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{Binding [Section_Output], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}"
                                   Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="TxtOutputPath"
                                     FontFamily="Consolas" FontSize="12"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="{Binding [Btn_Browse], Source={x:Static loc:LocalizationManager.Instance}}"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BtnBrowseOutput_Click"/>
                        </Grid>
                        <TextBlock Text="{Binding [Set_OutputHint], Source={x:Static loc:LocalizationManager.Instance}}"
                                   FontFamily="Verdana" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- App Data paths info -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{Binding [Section_AppData], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,0,16"/>
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding [Set_AppConfig], Source={x:Static loc:LocalizationManager.Instance}}" FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="TxtPathConfig"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding [Set_AppDevices], Source={x:Static loc:LocalizationManager.Instance}}" FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="TxtPathDevices"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding [Set_AppScans], Source={x:Static loc:LocalizationManager.Instance}}" FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="TxtPathScans"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="{Binding [Btn_OpenFolder], Source={x:Static loc:LocalizationManager.Instance}}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="10,6" FontSize="12"
                                    Click="BtnOpenAppData_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- About -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{Binding [Section_About], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <!-- SF Logo Tile -->
                            <Border Width="44" Height="44" CornerRadius="8"
                                    Background="#FF1A1A1A"
                                    VerticalAlignment="Center" Margin="0,0,14,0">
                                <Grid>
                                    <TextBlock Text="S" FontFamily="Georgia" FontStyle="Italic"
                                               FontWeight="Bold" FontSize="26" Foreground="#FFE8600A"
                                               HorizontalAlignment="Left" VerticalAlignment="Center"
                                               Margin="6,0,0,2"/>
                                    <TextBlock Text="F" FontFamily="Georgia" FontStyle="Italic"
                                               FontWeight="Bold" FontSize="26" Foreground="#FFF5F5F5"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,6,2"/>
                                </Grid>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Side" FontFamily="Verdana" FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="forge" FontFamily="Verdana" FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                    <TextBlock Text=" / NetworkLens" FontFamily="Verdana" FontSize="14"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center" Margin="6,2,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtVersion"
                                           Text="v1.3.5 — .NET 8 / WPF / Windows x64"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource AccentBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Credits -->
                        <Border Background="{DynamicResource BgDeepBrush}" CornerRadius="6"
                                Padding="14,12" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="💡 " FontFamily="Verdana" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding [About_Idea], Source={x:Static loc:LocalizationManager.Instance}}"
                                               FontFamily="Verdana" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="Jan Erik Mueller"
                                           FontFamily="Verdana" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🤖 " FontFamily="Verdana" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding [About_Development], Source={x:Static loc:LocalizationManager.Instance}}"
                                               FontFamily="Verdana" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1"
                                            Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Claude (Anthropic)"
                                               FontFamily="Verdana" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text=" — KI-Assistent von Anthropic"
                                               FontFamily="Verdana" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- License -->
                        <Border Background="#0A00B4D8" BorderBrush="#2200B4D8" BorderThickness="1"
                                CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚖" FontSize="14" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center">
                                    <Run Text="MIT License" FontWeight="SemiBold"
                                         Foreground="{DynamicResource AccentBrush}"/>
                                    <Run Text=" — "/><Run Text="{Binding [About_License], Source={x:Static loc:LocalizationManager.Instance}, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding [About_Description], Source={x:Static loc:LocalizationManager.Instance}}"
                                   FontFamily="Verdana" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,12"/>
                        <Button Content="{Binding [About_OpenGitHub], Source={x:Static loc:LocalizationManager.Instance}}"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,6" FontSize="12"
                                Click="BtnGitHub_Click"/>
                    </StackPanel>
                </Border>

                <!-- Changelog -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="{Binding [Section_Changelog], Source={x:Static loc:LocalizationManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,0,16"/>

                        <!-- v1.3.5 -->
                        <Expander Margin="0,0,0,8" IsExpanded="True">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{DynamicResource AccentBrush}"
                                            CornerRadius="4" Padding="7,2" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <TextBlock Text="v1.3.5" FontSize="11" FontWeight="Bold"
                                                   Foreground="#FF000000" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Text="Final Translation Polish"
                                               FontFamily="Verdana" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Margin="16,8,0,8">
                                <TextBlock Text="• Category dialog fully localized (Title, header, Apply button)"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Admin hint panel: 'Limited mode' + description translated"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Monitor AVG tooltip and ScanView progress text translated"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Report buttons: 'Open HTML report' and comparison status messages"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• 290 translation keys in Strings.cs"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                            </StackPanel>
                        </Expander>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4,0,8"/>

                        <!-- v1.3.2 -->
                        <Expander Margin="0,0,0,8" IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{DynamicResource BgDeepBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="4" Padding="7,2" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <TextBlock Text="v1.3.2" FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Text="Full Translation Coverage"
                                               FontFamily="Verdana" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Margin="16,8,0,8">
                                <TextBlock Text="• All dialogs translated: Alias, Category, Graph window"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• All MessageBoxes (errors, confirmations, hints) translated"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Status texts: 'X devices found', 'Scan complete', error messages"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Toast notifications: titles and descriptions"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Tooltips: MIN / AVG / MAX explanations"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• Notification checkboxes with icon prefix"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                                <TextBlock Text="• 280+ translation keys in Strings.cs"
                                           FontFamily="Verdana" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1"/>
                            </StackPanel>
                        </Expander>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4,0,8"/>

                        <!-- v1.3.1 -->
                        <Expander Margin="0,0,0,8" IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{DynamicResource BgDeepBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="4" Padding="7,2" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <TextBlock Text="v1.3.1" FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Consolas"/>
