<Window x:Class="NetworkLens.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NetworkLens.Views"
        Title="NetworkLens"
        Width="1200" Height="760"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgMainBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Effect>
        <DropShadowEffect Color="#FF000000" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
    </Window.Effect>

    <Border Background="{StaticResource BgMainBrush}" CornerRadius="10" BorderThickness="1"
            BorderBrush="{StaticResource BorderBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>   <!-- Title Bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="32"/>   <!-- Status Bar -->
            </Grid.RowDefinitions>

            <!-- ════════════════════════════════
                 CUSTOM TITLE BAR
                 ════════════════════════════════ -->
            <Border Grid.Row="0" Background="{StaticResource BgDeepBrush}"
                    CornerRadius="10,10,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- App Icon + Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="◈" FontSize="18" Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="NetworkLens" FontFamily="Segoe UI" FontSize="14"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Border x:Name="AdminBadge" Margin="10,0,0,0" CornerRadius="4"
                                Background="#1A00E676" BorderBrush="#3300E676" BorderThickness="1"
                                Padding="6,2" VerticalAlignment="Center" Visibility="Collapsed">
                            <TextBlock Text="ADMIN" FontSize="9" FontWeight="Bold"
                                       Foreground="{StaticResource StatusOnlineBrush}" FontFamily="Segoe UI"/>
                        </Border>
                        <Border x:Name="NoAdminBadge" Margin="10,0,0,0" CornerRadius="4"
                                Background="#1AFFAB00" BorderBrush="#33FFAB00" BorderThickness="1"
                                Padding="6,2" VerticalAlignment="Center">
                            <TextBlock Text="EINGESCHRÄNKT" FontSize="9" FontWeight="Bold"
                                       Foreground="{StaticResource StatusWarningBrush}" FontFamily="Segoe UI"/>
                        </Border>
                    </StackPanel>

                    <!-- Window Controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnMinimize" Content="—" Style="{StaticResource IconButton}"
                                Width="32" Height="32" FontSize="11"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Click="BtnMinimize_Click"/>
                        <Button x:Name="BtnMaximize" Content="⬜" Style="{StaticResource IconButton}"
                                Width="32" Height="32" FontSize="11"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Click="BtnMaximize_Click"/>
                        <Button x:Name="BtnClose" Content="✕" Style="{StaticResource IconButton}"
                                Width="32" Height="32" FontSize="11"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Click="BtnClose_Click">
                            <Button.Resources>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFCC0000"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ════════════════════════════════
                 MAIN CONTENT AREA
                 ════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>   <!-- Sidebar -->
                    <ColumnDefinition Width="1"/>     <!-- Divider -->
                    <ColumnDefinition Width="*"/>     <!-- Content -->
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0" Background="{StaticResource BgSidebarBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Nav Section Header -->
                        <TextBlock Grid.Row="0" Text="NAVIGATION" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"
                                   Margin="22,16,0,8"/>

                        <!-- Nav Items -->
                        <StackPanel Grid.Row="1" Margin="0,4">
                            <Button x:Name="NavScan" Tag="Active" Style="{StaticResource NavButton}"
                                    Click="NavButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬡" FontSize="15" Width="22" VerticalAlignment="Center"
                                               Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Text="Netzwerk-Scan" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="NavPorts" Style="{StaticResource NavButton}"
                                    Click="NavButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬡" FontSize="15" Width="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="Port-Scanner" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="NavInfo" Style="{StaticResource NavButton}"
                                    Click="NavButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬡" FontSize="15" Width="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="Netzwerk-Info" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="NavMonitor" Style="{StaticResource NavButton}"
                                    Click="NavButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬡" FontSize="15" Width="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="Live-Monitor" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="NavReport" Style="{StaticResource NavButton}"
                                    Click="NavButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬡" FontSize="15" Width="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="Report" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <!-- Separator -->
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="16,8"/>

                            <Button x:Name="NavSettings" Style="{StaticResource NavButton}"
                                    Click="NavButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬡" FontSize="15" Width="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="Einstellungen" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Sidebar Footer -->
                        <Border Grid.Row="2" BorderThickness="0,1,0,0"
                                BorderBrush="{StaticResource BorderBrush}" Padding="16,12">
                            <StackPanel>
                                <!-- Admin Restart hint (shown when not admin) -->
                                <Border x:Name="AdminHintPanel" Background="#1AFFAB00"
                                        BorderBrush="#33FFAB00" BorderThickness="1"
                                        CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="⚠ Eingeschränkter Modus"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource StatusWarningBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="Einige Features benötigen Admin-Rechte."
                                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" Margin="0,3,0,6"/>
                                        <Button Content="Als Admin neu starten"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="8,5" FontSize="11"
                                                Click="BtnRestartAdmin_Click"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="NetworkLens v1.0.0" FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Vertical Divider -->
                <Border Grid.Column="1" Background="{StaticResource BorderBrush}"/>

                <!-- CONTENT AREA -->
                <Grid Grid.Column="2" Background="{StaticResource BgMainBrush}">

                    <!-- Scan View (default) -->
                    <views:ScanView x:Name="ScanViewPage" Visibility="Visible"/>

                    <!-- Port Scan View -->
                    <views:PortScanView x:Name="PortScanViewPage" Visibility="Collapsed"/>

                    <!-- Network Info View -->
                    <views:NetworkInfoView x:Name="NetworkInfoViewPage" Visibility="Collapsed"/>

                    <!-- Monitor View -->
                    <views:MonitorView x:Name="MonitorViewPage" Visibility="Collapsed"/>

                    <!-- Report View -->
                    <views:ReportView x:Name="ReportViewPage" Visibility="Collapsed"/>

                    <!-- Settings View -->
                    <views:SettingsView x:Name="SettingsViewPage" Visibility="Collapsed"/>
                </Grid>
            </Grid>

            <!-- ════════════════════════════════
                 STATUS BAR
                 ════════════════════════════════ -->
            <Border Grid.Row="2" Background="{StaticResource BgDeepBrush}"
                    BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}"
                    CornerRadius="0,0,10,10">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Scan Summary -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusIndicator" Width="7" Height="7" Margin="0,0,7,0"
                                 Fill="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="StatusText" Text="Bereit"
                                   FontFamily="Segoe UI" FontSize="11.5"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right: Stats -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock x:Name="DeviceCount" Text="0 Geräte"
                                   FontFamily="Segoe UI" FontSize="11.5"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <Border Grid.Column="2" Width="1" Background="{StaticResource BorderBrush}"
                            Margin="0,8" Visibility="Collapsed"/>

                    <TextBlock Grid.Column="3" x:Name="ScanDuration"
                               FontFamily="Segoe UI" FontSize="11.5"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
